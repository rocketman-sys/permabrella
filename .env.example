# Database (Neon)
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-2.aws.neon.tech/permabrella?sslmode=require

# Auth.js (AUTH_* aliases supported in v5)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
AUTH_SECRET=generate-a-random-secret-here

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@permabrella.org

# Vercel Cron (set in Vercel; optional locally). Requests send Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=

# Eventbrite — org “private token” from https://www.eventbrite.com/platform/api-keys/
# EVENTBRITE_PRIVATE_TOKEN=
# Or alias:
# EVENTBRITE_API_KEY=
# EVENTBRITE_ORG_ID=
# Optional: set region slug for imported events (e.g. lismore)
# EVENTBRITE_DEFAULT_REGION=lismore

# Humanitix — public API key (Account → Advanced → Public API key)
# HUMANITIX_API_KEY=
# Optional region slug for imports
# HUMANITIX_DEFAULT_REGION=lismore
